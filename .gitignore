# Xcode build artifacts
# --------------------------------------------------

DerivedData/
build/
*.dSYM
*.dSYM.zip

# Xcode index database
*.xcactivitylog
*.hmap


# --------------------------------------------------
# Swift Package Manager
# --------------------------------------------------

.build/
.swiftpm/xcode/xcuserdata/

# Keep resolved versions for reproducible builds
!**/Package.resolved


# --------------------------------------------------
# Dependency managers
# --------------------------------------------------

Pods/
Carthage/Build/


