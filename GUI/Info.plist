	<key>NSDocumentsFolderUsageDescription</key>
	<string>MiMiNavigator needs access to Documents when you browse, copy, move, or compare files there.</string>
	<key>NSDownloadsFolderUsageDescription</key>
	<string>MiMiNavigator needs access to Downloads when you browse, copy, move, or compare files there.</string>
